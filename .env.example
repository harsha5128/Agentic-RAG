# Environment Variables Template
# Copy this file to .env and fill in the values

# ============================================
# API Keys and Credentials
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment

# ============================================
# AWS Configuration
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/your-account-id/your-queue
S3_BUCKET_NAME=your-rag-bucket

# ============================================
# Database Configuration
# ============================================
MONGODB_URI=mongodb://admin:changeme@localhost:27017/rag_db?authSource=admin
MONGODB_DATABASE=rag_db

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispass123
REDIS_DB=0

# ============================================
# RabbitMQ Configuration
# ============================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=rabbitmqpass123
RABBITMQ_VHOST=/

# ============================================
# Vector Database Configuration
# ============================================
VECTOR_DB_TYPE=pinecone  # Options: pinecone, weaviate, milvus
VECTOR_DB_DIMENSION=1536

# ============================================
# Service Configuration
# ============================================
SERVICE_NAME=agentic-rag
SERVICE_VERSION=1.0.0
ENVIRONMENT=development  # Options: development, staging, production
LOG_LEVEL=INFO
DEBUG=False

# ============================================
# Observability and Monitoring
# ============================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin

# ============================================
# Document Processing
# ============================================
MAX_FILE_SIZE_MB=100
SUPPORTED_FORMATS=pdf,docx,xlsx,csv,txt,jpg,png
OCR_ENABLED=true
MULTILINGUAL_SUPPORT=true

# ============================================
# Agentic Configuration
# ============================================
MAX_AGENTS=10
AGENT_TIMEOUT_SECONDS=300
STATE_PERSISTENCE_ENABLED=true
MEMORY_TYPE=redis  # Options: redis, mongodb

# ============================================
# LLM Configuration
# ============================================
LLM_MODEL_NAME=gpt-4-turbo-preview
EMBEDDING_MODEL_NAME=text-embedding-3-large
MAX_TOKENS=4096
TEMPERATURE=0.7
TOP_P=0.9

# ============================================
# RAG Configuration
# ============================================
CHUNK_SIZE=512
CHUNK_OVERLAP=100
RETRIEVAL_K=5
RERANKER_ENABLED=true

# ============================================
# Performance and Caching
# ============================================
CACHE_TTL_SECONDS=3600
CACHE_ENABLED=true
BATCH_SIZE=32

# ============================================
# Security
# ============================================
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
API_KEY_AUTH_ENABLED=true

# ============================================
# DVC Configuration
# ============================================
DVC_REMOTE=s3
DVC_S3_ENDPOINTURL=https://s3.amazonaws.com
DVC_NO_SCM=false
